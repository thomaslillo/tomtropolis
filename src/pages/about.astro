---
import PrimaryLayout from '../layouts/Primary.astro';
---

<PrimaryLayout>
    <div id="main-screen-div">           
        <div class="p-8 m-6 font-sans body-links bg-fixed bg-gray-100 shadow-md max-w-4xl">
            <h1 class="text-3xl font-bold text-gray-900 mb-4">Hi, I'm Tom.</h1>
            <h2 class="text-xl text-gray-700 mb-4">
                <a href="https://github.com/thomaslillo" class="text-blue-500 hover:text-blue-800">Github</a> | 
                <a href="https://www.linkedin.com/in/thomaslillo/" class="text-blue-500 hover:text-blue-800">LinkedIn</a>
            </h2>
            <section class="career-timeline mb-4" aria-label="Career progression timeline">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">What I've Been Doin'</h3>
                <div class="timeline-list">
                    <article class="timeline-item">
                        <span class="timeline-dot" aria-hidden="true"></span>
                        <div class="timeline-content">
                            <p class="timeline-era text-sm font-semibold text-gray-600">Senior Software Engineer</p>
                            <p class="timeline-date">Knotch (Current)</p>
                            <p class="text-gray-800">
                                Working as a Senior Software Engineer for a digital analytics SaaS company. Much of my work is building out the data services backend for our app.
                            </p>
                        </div>
                    </article>
                    <article class="timeline-item">
                        <span class="timeline-dot" aria-hidden="true"></span>
                        <div class="timeline-content">
                            <p class="timeline-era text-sm font-semibold text-gray-600">Analytics Consultant</p>
                            <p class="timeline-date">Woven Mining (My Company)</p>
                            <p class="text-gray-800">
                                General data science / engineering consulting work with a mining engineer friend. Largest project was supporting a junior mining company and their M&A efforts in South America with NLP analysis of mining data.
                            </p>
                        </div>
                    </article>
                    <article class="timeline-item">
                        <span class="timeline-dot" aria-hidden="true"></span>
                        <div class="timeline-content">
                            <p class="timeline-era text-sm font-semibold text-gray-600">Senior Data Engineer</p>
                            <p class="timeline-date">AutoTrader</p>
                            <p class="text-gray-800">
                                Worked for AutoTrader (part of AutoScout24), the worlds largest network of vehicle marketplaces, where I was on the central data team -
                                building new APIs with .NET Core then Python, pipelines, and doing some cloud/big data work in AWS, GCP, and Azure. It was a period of constant app and data migrations.
                            </p>
                        </div>
                    </article>
                    <article class="timeline-item">
                        <span class="timeline-dot" aria-hidden="true"></span>
                        <div class="timeline-content">
                            <p class="timeline-era text-sm font-semibold text-gray-600">Software Engineer</p>
                            <p class="timeline-date">Environics Analytics</p>
                            <p class="text-gray-800">
                                Spent a few years at Environics Analytics, the largest data broker in Canada. My first role there was on the Analytics consulting team helping clients use their data
                                effectively, then as a software developer where I built the data intensive reporting/data API for their analytics platform.
                            </p>
                        </div>
                    </article>
                    <article class="timeline-item">
                        <span class="timeline-dot" aria-hidden="true"></span>
                        <div class="timeline-content">
                            <p class="timeline-era text-sm font-semibold text-gray-600">Data Analyst</p>
                            <p class="timeline-date">Environics Analytics</p>
                            <p class="text-gray-800">
                                Spent a few years at Environics Analytics, the largest data broker in Canada. My first role there was on the Analytics consulting team helping clients use their data
                                effectively, then as a software developer where I built the data intensive reporting/data API for their analytics platform.
                            </p>
                        </div>
                    </article>
                    <article class="timeline-item">
                        <span class="timeline-dot" aria-hidden="true"></span>
                        <div class="timeline-content">
                            <p class="timeline-era text-sm font-semibold text-gray-600">Events Company Founder (University)</p>
                            <p class="timeline-date">Datathon (My Company)</p>
                            <p class="text-gray-800">
                                In University, I co-founded a data science conference and workshop company called
                                <a href="https://thomaslillo.github.io/datathon-website-tailwindcss/" class="text-blue-500 hover:text-blue-800">Datathon Analytics Events</a>. We raised just over <strong class="font-semibold">CAD $50,000</strong> in sponsorships to provide free and low-cost educational events teaching hundreds of students to code and connecting them with industry. See an article about it
                                <a href="https://brocku.ca/brock-news/tag/datathon/" class="text-blue-500 hover:text-blue-800">here</a> or the
                                <a href="https://thomaslillo.github.io/datathon-website-tailwindcss/" class="text-blue-500 hover:text-blue-800">old website</a>.
                            </p>
                        </div>
                    </article>
                </div>
            </section>
            <p class="text-gray-800">
                My github account above serves as my portfolio if you're interested, but there are also some examples of my work below and on my content page.
            </p>
            <br>
            <section class="likes-section mb-4" aria-label="Things I like with examples">
                <h2 class="text-xl mb-4 text-gray-900">Some things I like with examples:</h2>
                <ul class="likes-list list-disc">
                    <li class="likes-item text-gray-500">
                        <span class="font-semibold text-black">Spatial data science:</span> I'm an award-winning map maker, featured in the 
                        <a href="https://map-calendar-esricanada.hub.arcgis.com/pages/aug-2021" class="text-blue-500 hover:text-blue-800">ESRI calendar</a> and 
                        <a href="https://www.esri.com/en-us/esri-press/browse/the-esri-map-book-volume-38" class="text-blue-500 hover:text-blue-800">ESRI map book</a>.
                    </li>
                    <li class="likes-item text-gray-500">
                        <span class="font-semibold text-black">Building things to solve problems without over-engineering:</span> 1st place of a Major League Hackathon with a map-based agri-tourism aggregator, detailed 
                        <a href="https://devpost.com/software/agritech-hackathon-2020-opentourism-niagara" class="text-blue-500 hover:text-blue-800">here</a>. Which uses existing spatial data from google maps in a new UI to improve attraction discovery.
                    </li>
                    <li class="likes-item text-gray-500">
                        <span class="font-semibold text-black">Building successful analytics and software capabilities or systems:</span> Which includes teaching skills, like Python, as I did at the 
                        <a href="https://github.com/thomaslillo/spatial-python-bootcamp" class="text-blue-500 hover:text-blue-800">Spatial Data Science Bootcamp</a>.
                    </li>
                    <li class="likes-item text-gray-500">
                        <span class="font-semibold text-black">Volunteering my tech skills for civic good:</span> An example being this 
                        <a href="https://github.com/CivicTechTO/missing-persons" class="text-blue-500 hover:text-blue-800">Civic Tech Toronto project</a>
                        for the CBC's 5th Estate, that helps citizens match missing persons database entries to unidentified remains using the RCMP database.
                    </li>
                </ul>
                <div class="text-gray-600 m-4 font-sans text-center">
                    <h3 class="text-xl mb-4 font-mono">If you need data help reach out to me!</h3>
                </div>
            </section>
        </div>
        <div class="p-8 m-6 max-w-4xl body-links grid justify-items-center">            
            <h1 class="mb-4">Who can help solve your data issues?</h1>
            <video width="400" controls>
            <source src="/Prime_Time_Truth.mp4" type="video/mp4">
            Your browser does not support HTML video.
            </video>

            <p class="mb-4">
            Video courtesy of 
            <a href="https://github.com/ThePrimeagen" target="_blank">ThePrimeagen</a>.
            </p>            
        </div>
    </div>
</PrimaryLayout>
<style>
    p {
        line-height: 1.5;
    }

    .career-timeline {
        position: relative;
        border-radius: 0.75rem;
        padding: 1rem;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(243, 244, 246, 0.7) 100%);
        border: 1px solid #d1d5db;
    }

    .timeline-list {
        position: relative;
        display: grid;
        gap: 1rem;
    }

    .timeline-list::before {
        content: "";
        position: absolute;
        top: 0.25rem;
        left: 0.5rem;
        bottom: 0.25rem;
        width: 2px;
        background: linear-gradient(180deg, #1d4ed8 0%, #93c5fd 100%);
    }

    .timeline-item {
        display: grid;
        grid-template-columns: 1rem 1fr;
        gap: 0.75rem;
        align-items: start;
    }

    .timeline-dot {
        display: inline-block;
        width: 1rem;
        height: 1rem;
        border-radius: 9999px;
        background: #1d4ed8;
        border: 3px solid #dbeafe;
        box-shadow: 0 0 0 2px #1d4ed8;
        margin-top: 0.25rem;
        z-index: 1;
    }

    .timeline-content {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        padding: 0.75rem;
    }

    .timeline-era {
        line-height: 1.1;
        margin-bottom: 0.2rem;
        letter-spacing: 0.03em;
        text-transform: uppercase;
    }

    .timeline-date {
        margin-bottom: 0.45rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: #2563eb;
        letter-spacing: 0.02em;
    }

    .likes-section {
        border-radius: 0.75rem;
        padding: 1rem;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(243, 244, 246, 0.7) 100%);
    }

    .likes-list {
        display: grid;
        gap: 1rem;
        padding-left: 1.5rem;
    }

    .likes-item {
        background: #ffffff;
        border-radius: 0.5rem;
        padding: 0.75rem 0.9rem;
    }

    @media (max-width: 640px) {
        .career-timeline {
            padding: 0.85rem;
        }

        .timeline-content {
            padding: 0.65rem;
        }

        .likes-section {
            padding: 0.85rem;
        }

        .likes-item {
            padding: 0.65rem 0.8rem;
        }
    }
</style>
