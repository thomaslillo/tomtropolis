---
const currentPath = Astro.url.pathname;
---
<nav class="flex flex-wrap justify-between items-center gap-2" aria-label="Primary navigation">
    <div class="title p-4 md:p-8">
        <a href="/" class="flex items-center">
            <span class="text-lg md:text-3xl flex items-center" aria-label="Tomtropolis home"><span aria-hidden="true">⌘</span>&nbsp;Tomtropolis</span>
        </a>
    </div>
    <div class="links px-2">
        <ul class="flex flex-wrap gap-2">
            <li class="px-4">
                <a href="/about" class:list={["text-sm md:text-xl", { "font-bold underline": currentPath === "/about" }]} aria-current={currentPath === "/about" ? "page" : undefined}>/about</a>
            </li>
            <li class="px-4">
                <a href="/content" class:list={["text-sm md:text-xl", { "font-bold underline": currentPath === "/content" }]} aria-current={currentPath === "/content" ? "page" : undefined}>/content</a>
            </li>
        </ul>
    </div>
</nav>
