    <div class="mt-2">
        <div class="flex flex-wrap justify-center gap-2">
        <button id="colorShuffleBtn" class="text-sm px-3 py-1 bg-white bg-opacity-30 rounded hover:bg-opacity-50 flex items-center mx-auto" type="button">
            <span aria-hidden="true">🎨</span> Shuffle Colors
        </button>
        <button id="themeToggleBtn" class="text-sm px-3 py-1 bg-white bg-opacity-30 rounded hover:bg-opacity-50" type="button" aria-pressed="false">
            Use dark mode
        </button>
        </div>
    </div>
    <link rel="stylesheet" href="https://townsquare.cauenapier.com/widget.css" />
    <div id="townsquare-root"></div>
    <script type="module" is:inline>
        import { mountTownSquare } from "https://townsquare.cauenapier.com/townsquare.mjs";

        mountTownSquare(document.getElementById("townsquare-root"), {
            serverOrigin: "https://townsquare.cauenapier.com",
            siteKey: "site_FOqccrys6vKapXfb",
            scene: {"benches":2,"benchXs":[0.18,0.69],"trees":3,"treeXs":[0.77,0.61,0.26],"lamps":0,"lampXs":[],"birds":4},
            theme: "host"
        });
    </script>
